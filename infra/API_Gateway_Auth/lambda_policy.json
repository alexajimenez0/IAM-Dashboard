{
  "Version": "2012-10-17",
  "Statement": [
    {
		"Effect": "Allow",
			"Action": [
			"logs:CreateLogGroup",
			"logs:CreateLogStream",
			"logs:PutLogEvents"
			],
			"Resource": "*"
		},
    {
      "Sid": "AllowCognitoUserPoolAuthFlows",
      "Effect": "Allow",
      "Action": [
        "cognito-idp:InitiateAuth",
        "cognito-idp:RespondToAuthChallenge"
      ],
      "Resource": "arn:aws:cognito-idp:us-east-1:562559071105:userpool/us-east-1_ITzOhtZfA"
    },
    {
      "Sid": "AllowSessionTableAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:562559071105:table/iam-dashboard-scan-results"
    }
  ]
}
